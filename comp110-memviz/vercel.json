{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://comp110-26s.github.io https://*.github.io https://*.unc.edu"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://comp110-26s.github.io"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
